APP_NAME="EPAS-E"
APP_ENV=local
APP_KEY=base64:cmlj7hd90xes1FRM4WLWyXAvRTapeOxzyWOln2bIKkA=
APP_DEBUG=true # Set true for local development only
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# ============================================================================
# HTTPS / SSL Configuration
# ============================================================================
#
# LOCAL DEVELOPMENT (no tunnel):
#   FORCE_HTTPS=false
#   TRUSTED_PROXIES=
#
# CLOUDFLARE TUNNEL (auto-detected, just run: cloudflared tunnel --url http://127.0.0.1:8000):
#   FORCE_HTTPS=false   (auto-detects from X-Forwarded-Proto header)
#   TRUSTED_PROXIES=*
#
# PRODUCTION:
#   FORCE_HTTPS=true
#   TRUSTED_PROXIES=<your-proxy-ips>  (or Cloudflare IP ranges)
#
FORCE_HTTPS=false

# Trusted proxies - use '*' for Cloudflare tunnel, specific IPs for production
TRUSTED_PROXIES=*

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=epas_db
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# For production with Redis, use: QUEUE_CONNECTION=redis

CACHE_STORE=file
# For production with Redis, use: CACHE_STORE=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Gmail SMTP Configuration
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to: Google Account > Security > 2-Step Verification > App passwords
# 3. Generate an App Password and paste it below
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=khirviecliffordbautista@gmail.com
MAIL_PASSWORD="rodn kjjc qwjh vxsh"
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=khirviecliffordbautista@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
